# Playback Server Configuration - Production

# HTTP server
HTTP_PORT=9247

# Logging level (debug, info, warn, error)
RUST_LOG=info

ZENOH_CONNECT_ENDPOINTS=udp/127.0.0.1:7447

# CORS (for API access from control-panel)
CORS_ENABLED=false
# CORS_ORIGIN must be set when CORS_ENABLED=true
# Example: CORS_ORIGIN=http://localhost:7381

{
	"extends": "stylelint-config-standard",
	"rules": {
		"color-named": "never",
		"no-empty-source": true,
		"no-irregular-whitespace": true,
		"no-descending-specificity": null,
		"custom-property-pattern": null,
		"selector-class-pattern": null,
		"selector-id-pattern": null,
		"max-nesting-depth": 3,

		"function-no-unknown": [true, { "ignoreFunctions": ["min", "max", "clamp"] }],
		"unit-no-unknown": [true, { "ignoreUnits": ["vh", "vw"] }],
		"selector-pseudo-class-no-unknown": [true, { "ignorePseudoClasses": ["global"] }],
		"selector-pseudo-element-no-unknown": [true, { "ignorePseudoElements": ["global"] }],
		"at-rule-no-unknown": [
			true,
			{
				"ignoreAtRules": ["apply", "layer", "tailwind", "apply", "responsive", "screen"]
			}
		]
	},
	"ignoreFiles": [
		"**/*.generated.css",
		"node_modules/**/*",
		"dist/**/*",
		"build/**/*",
		".svelte-kit/**/*"
	]
}

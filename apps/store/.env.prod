# Store Server Configuration - Production

# HTTP server
PORT=61532

# Database
DATABASE_URL=sqlite:slideshows.db

# Media directory
MEDIA_DIR=./media

# Logging level (debug, info, warn, error)
RUST_LOG=info

# CORS (for API access from control-panel)
CORS_ENABLED=false
# CORS_ORIGIN must be set when CORS_ENABLED=true
# Example: CORS_ORIGIN=http://localhost:7381
